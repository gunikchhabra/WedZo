<!-- resp.locals.success = resp.locals.error = array  -->

<% if(success && success.length){ %>

<div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative w-1/2 mx-auto role='alert'">
  <span class="block sm:inline"><%=success %></span>
  <button
  type="button"
  onclick="this.parentElement.remove()"
  class="ml-4 text-green-700 hover:text-green-900 font-bold text-xl leading-none ml-auto flex items-center"
  aria-label="Close"
>
  &times;
</button>
</div>
<% } %>

<% if(error && error.length) { %>

<div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative w-1/2 mx-auto role='alert' ">
  <span class="block sm:inline"><%=error %></span>
  <button
  type="button"
  onclick="this.parentElement.remove()"
  class="ml-4 text-red-700 hover:text-red-900 font-bold text-xl leading-none ml-auto flex items-center"
  aria-label="Close"
>
  &times;
</button>
</div>
<% } %>