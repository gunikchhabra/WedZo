<% layout("/layouts/boilerplate") %>

<div class="max-w-3xl mx-auto px-6 py-10">

  <h2 class="text-2xl font-semibold text-[#3e2f23] mb-6">
    Delivery Details
  </h2>

  <form action="/order/checkout" method="POST" class="space-y-4">

    <input name="Add[add1]" placeholder="Address Line 1"
      class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-[#b8965a]" required>

    <input name="Add[add2]" placeholder="Address Line 2"
      class="w-full border rounded-lg px-4 py-2">

    <div class="grid grid-cols-2 gap-4">
      <input name="Add[city]" placeholder="City"
        class="border rounded-lg px-4 py-2" required>

      <input name="Add[state]" placeholder="State"
        class="border rounded-lg px-4 py-2" required>
    </div>

    <input name="Add[pincode]" placeholder="Pincode"
      class="w-full border rounded-lg px-4 py-2" required>

    <button class="w-full mt-4 bg-[#b8965a] text-white py-2.5 rounded-full hover:bg-[#a6844d]">
      Continue to Payment
    </button>

  </form>

</div>