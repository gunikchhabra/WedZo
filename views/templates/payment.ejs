<% layout("/layouts/boilerplate") %>

<div class="max-w-3xl mx-auto px-6 py-10">

  <h2 class="text-2xl font-semibold text-[#3e2f23] mb-6">
    Payment Method
  </h2>

  <form action="/order/placeOrder" method="POST" class="space-y-4">

    <!-- COD -->
    <label class="flex items-center gap-3 border p-4 rounded-lg cursor-pointer">
      <input type="radio" name="payment" value="COD" required>
      <span>Cash on Delivery</span>
    </label>

    <!-- Disabled options -->
    <label class="flex items-center gap-3 border p-4 rounded-lg opacity-50">
      <input type="radio" disabled>
      <span>UPI (Coming Soon)</span>
    </label>

    <label class="flex items-center gap-3 border p-4 rounded-lg opacity-50">
      <input type="radio" disabled>
      <span>Card (Coming Soon)</span>
    </label>

    <button class="w-full mt-4 bg-[#b8965a] text-white py-2.5 rounded-full hover:bg-[#a6844d]">
      Place Order
    </button>

  </form>

</div>