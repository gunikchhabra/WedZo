<% layout("layouts/boilerplate.ejs") %>

<section class="bg-[#faf7f2] min-h-screen">

  <div class="max-w-4xl mx-auto px-6 py-16">

    <h1 class="text-4xl font-semibold text-[#3e2f23] mb-6">
      About Wedzo
    </h1>

    <p class="text-[#6b5a4a] leading-relaxed mb-6">
      Wedzo is a platform built to simplify wedding shopping by bringing
      premium clothing and fabric collections from local boutiques directly
      to your screen.
    </p>

    <p class="text-[#6b5a4a] leading-relaxed mb-6">
      We believe that every design deserves to be seen. From small markets
      to independent sellers, Wedzo helps showcase unique styles across
      different parts of India — making them accessible to everyone.
    </p>

    <p class="text-[#6b5a4a] leading-relaxed mb-10">
      Whether you're preparing for your big day or simply exploring elegant
      fabrics, Wedzo makes discovering, choosing, and ordering effortless.
    </p>

    <!-- Highlight Section -->
    <div class="grid md:grid-cols-3 gap-6 text-center">

      <div class="bg-white p-6 rounded-xl border border-[#e5ddd2]">
        <p class="font-medium text-[#3e2f23]">Curated Designs</p>
        <p class="text-sm text-[#6b5a4a]">Handpicked collections</p>
      </div>

      <div class="bg-white p-6 rounded-xl border border-[#e5ddd2]">
        <p class="font-medium text-[#3e2f23]">Pan India Reach</p>
        <p class="text-sm text-[#6b5a4a]">Styles from every corner</p>
      </div>

      <div class="bg-white p-6 rounded-xl border border-[#e5ddd2]">
        <p class="font-medium text-[#3e2f23]">Easy Experience</p>
        <p class="text-sm text-[#6b5a4a]">Smooth & reliable shopping</p>
      </div>

    </div>

  </div>

</section>