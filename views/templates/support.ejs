<% layout("layouts/boilerplate.ejs") %>

<section class="bg-[#faf7f2] min-h-screen">

  <div class="max-w-xl mx-auto px-6 py-16">

    <!-- Heading -->
    <h1 class="text-4xl font-semibold text-[#3e2f23] mb-4">
      Support
    </h1>

    <p class="text-[#6b5a4a] mb-8">
      Have a question or need help with your order? We're here to assist you.
    </p>

    <!-- Contact Info -->
    <div class="bg-white p-6 rounded-2xl border border-[#e5ddd2] shadow-sm mb-8">
      <p class="font-medium text-[#3e2f23] mb-2">Contact Us</p>

      <p class="text-sm text-[#6b5a4a]">
        📧 support@wedzo.com
      </p>

      <p class="text-sm text-[#6b5a4a] mt-2">
        📞 +91 6283800821
      </p>
    </div>

    <!-- Form -->
    <form class="space-y-4 bg-white p-6 rounded-2xl border border-[#e5ddd2] shadow-sm">

      <input type="text" placeholder="Your Name"
        class="w-full border border-[#e5ddd2] rounded-lg px-4 py-2 outline-none 
               focus:ring-2 focus:ring-[#b8965a]">

      <input type="email" placeholder="Your Email"
        class="w-full border border-[#e5ddd2] rounded-lg px-4 py-2 outline-none 
               focus:ring-2 focus:ring-[#b8965a]">

      <textarea rows="4" placeholder="Your Message"
        class="w-full border border-[#e5ddd2] rounded-lg px-4 py-2 outline-none 
               focus:ring-2 focus:ring-[#b8965a]"></textarea>

      <button 
        class="w-full bg-[#b8965a] text-white py-2 rounded-lg 
               hover:bg-[#a07f47] transition duration-200">
        Send Message
      </button>

    </form>

  </div>

</section>