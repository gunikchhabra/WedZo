<% layout("/layouts/boilerplate") %>
<div class="max-w-7xl mx-auto px-6 mt-10">

  <div class="grid gap-8 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3">

    <% for (let shop of data) { %>

    <div class="bg-[#f9f6f2] rounded-2xl overflow-hidden 
                border border-[#e0d8cc] shadow-sm 
                hover:shadow-lg hover:-translate-y-1 transition duration-300">

      <!-- Image -->
      <a href="/shops/<%= shop._id %>">
        <div class="w-full aspect-[4/3] bg-gray-100">
          <img src="<%= shop.shopImage %>" 
               class="w-full h-full object-cover">
        </div>
      </a>

      <!-- Content -->
      <div class="p-5">

        <h5 class="text-lg font-semibold text-[#3e2f23] tracking-wide">
          <%= shop.shopName %>
        </h5>

        <p class="text-sm text-gray-600 mt-1">
          <%= shop.address %>
        </p>

        <p class="text-sm text-gray-500 mt-1">
          Owner: <%= shop.username %>
        </p>

        <p class="text-sm text-gray-500">
          📞 <%= shop.contactNo %>
        </p>

        <!-- Button -->
        <a href="/shop/<%= shop._id %>" 
           class="mt-4 inline-block w-full text-center 
                  bg-[#b8965a] text-white py-2 rounded-full 
                  hover:bg-[#a6844d] transition shadow-sm">
          Visit Store →
        </a>

      </div>

    </div>

    <% } %>

  </div>

</div>